# Copy this file to .env in this folder and fill in your values.
#   copy env.example .env

# PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/telemetryx

# Redis (Celery broker + analysis cache)
REDIS_URL=redis://localhost:6379/0

# Cache TTL for repeated repo analysis (seconds, default 3600 = 1 hour)
ANALYSIS_CACHE_TTL=3600
